# ===========================================
# Merizona Marketplace — Environment Variables
# ===========================================
# Copy to .env and fill in actual values

# --- Database (PostgreSQL / TypeORM) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/merizona
DATABASE_SSL=false

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Elasticsearch ---
ELASTICSEARCH_NODE=http://localhost:9200

# --- MinIO (S3-compatible) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PRODUCTS=product-images
MINIO_BUCKET_VENDORS=vendor-logos
MINIO_BUCKET_INVOICES=invoices

# --- Auth (JWT) ---
JWT_SECRET=change-me-to-a-strong-random-secret-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Shipping (Shippo) ---
SHIPPO_API_KEY=shippo_test_...
SHIPPO_WEBHOOK_SECRET=whsec_...

# --- App ---
API_PORT=3001
API_GLOBAL_PREFIX=api/v1
FRONTEND_URL=http://localhost:3000
INTERNAL_API_SECRET=change-me-internal-shared-secret

# --- NestJS Internal URL (for Next.js to call) ---
NEST_INTERNAL_URL=http://localhost:3001
