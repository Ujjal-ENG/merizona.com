{
  "name": "@merizona/api",
  "version": "0.1.0",
  "private": true,
  "description": "Merizona Marketplace — NestJS API",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
