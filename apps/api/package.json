    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "seed": "ts-node --transpile-only --project scripts/tsconfig.json scripts/seed.ts"
  },
  "dependencies": {
    "@casl/ability": "^6.7.2",
    "@fastify/cookie": "^10.0.1",
    "@nestjs/common": "^11.0.0",
